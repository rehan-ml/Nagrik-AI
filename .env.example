# Copy this file to .env and fill in your real values.
# Never commit the actual .env file — it's already listed in .gitignore.

# Your Gemini API key from Google AI Studio.
# New keys are issued in the "AQ." format (replacing the older "AIza..." format).
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use. Defaults to gemini-3.1-flash-lite if not set.
GEMINI_MODEL=gemini-3.1-flash-lite

# PORT is set automatically by Render in production — no need to set it locally
# unless you want to run on a specific port, e.g.:
# PORT=8080
